# ===================================================
# Librachat — Environment Variables
# Скопируйте в .env.local и заполните значения
# ===================================================

# Сайт
NEXT_PUBLIC_SITE_URL=https://librachat.ai

# Strapi CMS
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=your_strapi_api_token_here

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Yandex Metrika
NEXT_PUBLIC_YM_COUNTER_ID=XXXXXXXX

# Форма обратной связи (например, Resend или SMTP)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL=hello@librachat.ai
